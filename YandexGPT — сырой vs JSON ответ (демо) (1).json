        "jsonBody": "={\n  \"modelUri\": \"{{ $('Параметры').item.json.model_uri }}\",\n  \"completionOptions\": {\n    \"stream\": false,\n    \"temperature\": 0.3,\n    \"maxTokens\": \"500\"\n  },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"text\": \"Ты ассистент службы поддержки. Проанализируй обращение клиента и дай развёрнутый комментарий: что произошло, насколько серьёзно, что делать дальше.\"\n    },\n    {\n      \"role\": \"user\",\n      \"text\": \"{{ $('Параметры').item.json.input_text }}\"\n    }\n  ]\n}",
