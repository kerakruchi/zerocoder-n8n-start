        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"modelUri\": \"{{ $('Параметры').item.json.model_uri }}\",\n  \"completionOptions\": {\n    \"stream\": false,\n    \"temperature\": 0.1,\n    \"maxTokens\": \"500\"\n  },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"text\": \"Ты классификатор обращений клиентов. Проанализируй обращение и верни ответ СТРОГО в формате JSON без какого-либо другого текста, без markdown-обёртки, без пояснений. Структура: {\\\"severity\\\": \\\"low|medium|high|critical\\\", \\\"category\\\": \\\"delivery|quality|payment|service|other\\\", \\\"summary\\\": \\\"одно предложение что произошло\\\", \\\"suggested_action\\\": \\\"что должен сделать оператор\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"text\": \"{{ $('Параметры').item.json.input_text }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "3533200c-ace8-4f7b-84dd-20b2d4311319",
      "name": "YandexGPT — JSON ответ",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -448,
        176
      ]
    },
    {
      "parameters": {
        "jsCode": "// Берём текст из ответа YandexGPT\nconst raw = $input.first().json.result.alternatives[0].message.text;\n\n// Иногда модель оборачивает JSON в ```json ... ``` — чистим\nlet cleaned = raw.trim();\nif (cleaned.startsWith('```')) {\n  cleaned = cleaned.replace(/^```(?:json)?\\s*/i, '').replace(/```\\s*$/, '').trim();\n}\n\n// Парсим JSON в реальный объект\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (err) {\n  throw new Error('Модель вернула не валидный JSON: ' + raw);\n}\n\n// Возвращаем поля как обычные ключи — теперь к ним можно обращаться $json.severity и т.д.\nreturn [{ json: parsed }];"
      },
      "id": "5e01cd8d-a9af-4b74-ae45-9222b8ab8da7",
