        "jsCode": "// Источник вернул ОДНУ запись с массивом клиентов внутри.\n// Так часто работают API: один response → пачка объектов в поле data/customers/items.\n\nreturn [{\n  json: {\n    batchId: \"batch-2026-06-09-001\",\n    receivedAt: new Date().toISOString(),\n    customers: [\n      { id: 1, name: \"Анна Петрова\",      phone: \"+7 916 123-45-67\", source: \"сайт\" },\n      { id: 2, name: \"Иван Сидоров\",      phone: \"\",                  source: \"сайт\" },\n      { id: 3, name: \"Мария Иванова\",     phone: \"+7 925 987-65-43\", source: \"instagram\" },\n      { id: 4, name: \"Олег Кузнецов\",     phone: \"+7 903 555-12-34\", source: \"сайт\" },\n      { id: 5, name: \"Елена Смирнова\",    phone: \"\",                  source: \"telegram\" },\n      { id: 6, name: \"Дмитрий Новиков\",   phone: \"+7 905 222-33-44\", source: \"сайт\" },\n      { id: 7, name: \"Светлана Морозова\", phone: \"+7 962 111-22-33\", source: \"instagram\" },\n      { id: 8, name: \"Павел Орлов\",       phone: null,                source: \"telegram\" }\n    ]\n  }\n}];"
