      "parameters": {
        "jsCode": "const r = ($input.first().json.result) || [];\nconst text = r.map(x => x.payload && x.payload.text).filter(Boolean).join('\\n\\n');\nreturn [{ json: { response: text || 'В базе знаний ничего не найдено по этому вопросу.' } }];"
